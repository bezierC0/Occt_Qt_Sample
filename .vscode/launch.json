{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Qt App (CMake)",
            "type": "cppvsdbg", // C++ debug type
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}", 
            "args": [], 
            "stopAtEntry": false,
            "cwd": "${command:cmake.launchTargetDirectory}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${env:PATH};"
                }
            ],
            //"externalConsole": false, 
            "console": "internalConsole",
            "visualizerFile": "${workspaceFolder}/.vscode/main.natvis",
            "preLaunchTask": "CMake: build"
        }
    ]
}